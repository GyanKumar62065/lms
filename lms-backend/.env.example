NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://mongo:27017/lms
MONGO_POOL_MIN=2
MONGO_POOL_MAX=20
JWT_ACCESS_SECRET=change-me-to-a-32+char-random-string-aaaa
JWT_REFRESH_SECRET=change-me-to-a-32+char-random-string-bbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_PEPPER=change-me-to-a-random-secret
BCRYPT_ROUNDS=12
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=salary-slips
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
# Optional — captcha expiry in seconds (default: 300)
CAPTCHA_TTL_SECONDS=300
