# --- Mongo ---
MONGO_INITDB_DATABASE=lms

# --- Backend ---
NODE_ENV=production
PORT=4000
MONGO_URI=mongodb://mongo:27017/lms?replicaSet=rs0
MONGO_POOL_MIN=2
MONGO_POOL_MAX=20
JWT_ACCESS_SECRET=replace-with-32+char-random-string-aaaaaaaa
JWT_REFRESH_SECRET=replace-with-32+char-random-string-bbbbbbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_PEPPER=replace-with-a-random-secret
BCRYPT_ROUNDS=12
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=salary-slips
CORS_ORIGIN=http://localhost:3100
COOKIE_SECURE=false

# --- Frontend ---
NEXT_PUBLIC_API_URL=/api/v1
API_URL_INTERNAL=http://backend:4000/api/v1

BACKEND_ORIGIN=http://backend:4000
